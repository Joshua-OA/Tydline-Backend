# Core
ENVIRONMENT=development

# Database (Supabase Postgres pooler — pgbouncer, port 6543)
DATABASE_URL=postgresql+asyncpg://user:password@host:6543/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ShipsGo container tracking API (v2 Ocean)
SHIPSGO_API_KEY=your-shipsgo-user-token
SHIPSGO_API_BASE_URL=https://api.shipsgo.com/v2

# Groq (AI alert generation + logistics agent)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_AGENT=qwen/qwen3-32b

# Langfuse (LLM observability — https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Mem0 (agent conversation memory — https://app.mem0.ai)
MEM0_API_KEY=m0-...

# Inbound email (Postmark — required for tracking email webhook)
POSTMARK_SERVER_TOKEN=your-postmark-token
POSTMARK_INBOUND_SECRET=youruser:yourpassword

# Outbound email provider: "resend" (recommended) or "postmark"
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@yourdomain.com

# Resend (outbound) — https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# WhatsApp Business API (Meta)
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# API security — set a strong random secret
API_KEY=your-strong-random-api-key
WHATSAPP_WEBHOOK_SECRET=<your-secret>
WHATSAPP_PROXY_URL=https://your-proxy.com/send

# Frontend URL (used in magic-link emails)
FRONTEND_URL=https://app.tydline.com

# CORS — JSON array of allowed origins (pydantic-settings v2 list format)
# Add "http://localhost:5174" when developing locally against the production API
CORS_ORIGINS=["https://www.tydline.com","https://tydline.com","http://localhost:5174"]

# Moolre MoMo payment integration
MOOLRE_API_USER=your-moolre-api-user
MOOLRE_PUBLIC_KEY=your-moolre-public-key
MOOLRE_AMOUNT=99.00
MOOLRE_WEBHOOK_SECRET=your-moolre-webhook-secret